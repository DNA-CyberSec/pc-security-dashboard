rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User document ──────────────────────────────────────────────────────
    // Client can read their own user doc (needed for Setup page token display).
    // Client can create/update their own user doc (e.g. language preference)
    // but CANNOT set or modify server-controlled fields (agentToken,
    // agentTokenCreatedAt) — those are written exclusively by Cloud Functions.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // On create: client may not set agentToken / agentTokenCreatedAt
      allow create: if request.auth != null && request.auth.uid == uid
        && !("agentToken"          in request.resource.data)
        && !("agentTokenCreatedAt" in request.resource.data);

      // On update: client may not change agentToken / agentTokenCreatedAt
      // once set by the Cloud Function.  Comparing to resource.data (the
      // existing doc) guards against overwrite; the guard only fires when the
      // field already exists so a brand-new user doc still works.
      allow update: if request.auth != null && request.auth.uid == uid
        && (!("agentToken" in resource.data)
            || request.resource.data.agentToken == resource.data.agentToken)
        && (!("agentTokenCreatedAt" in resource.data)
            || request.resource.data.agentTokenCreatedAt == resource.data.agentTokenCreatedAt);

      // ── Per-device data ──────────────────────────────────────────────────
      // Device documents are created and fully managed by Cloud Functions.
      // The only client-allowed write is updating the "nickname" field.
      match /devices/{deviceId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if false;  // Cloud Functions only
        allow delete: if false;  // Cloud Functions only
        // Client may only change the nickname field; all other fields are server-controlled
        allow update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["nickname"]);

        // Full scan data
        match /scans/{scanId} {
          allow read:   if request.auth != null && request.auth.uid == uid;
          allow create: if request.auth != null && request.auth.uid == uid;
          allow update: if request.auth != null && request.auth.uid == uid;
          allow delete: if false;
        }

        // Security summary — written by Cloud Functions only
        match /security/{doc} {
          allow read:  if request.auth != null && request.auth.uid == uid;
          allow write: if false;
        }

        // Live CPU/RAM — written by Cloud Functions only
        match /realtime/{doc} {
          allow read:  if request.auth != null && request.auth.uid == uid;
          allow write: if false;
        }

        // Network status — written by Cloud Functions only
        match /network/{doc} {
          allow read:  if request.auth != null && request.auth.uid == uid;
          allow write: if false;
        }

        // Linux agent commands — queued by Cloud Functions, read by client for status
        match /commands/{commandId} {
          allow read:  if request.auth != null && request.auth.uid == uid;
          allow write: if false;
        }
      }
    }

    // ── Agent tokens — never readable by clients ───────────────────────────
    match /agentTokens/{token} {
      allow read, write: if false;
    }

    // ── Per-token rate limit state — written by Cloud Functions only ────────
    match /rateLimits/{token} {
      allow read, write: if false;
    }

    // ── Global config (latest agent version, etc.) — authenticated read only ─
    match /config/{doc} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Deny everything else ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
