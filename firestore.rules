rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents and all subcollections ──────────────────────────────
    // Each user can only access their own data. No cross-user reads possible.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Scans subcollection — user-owned, no deletion
      match /scans/{scanId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update: if request.auth != null && request.auth.uid == uid;
        allow delete: if false;
      }

      // Agent status subcollection — user reads, agent writes via Cloud Function
      match /agent/{doc} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false; // only written by Cloud Functions (Admin SDK)
      }

      // Realtime heartbeat subcollection — user reads, agent writes via Cloud Function
      match /realtime/{doc} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false; // only written by Cloud Functions (Admin SDK)
      }
    }

    // ── Agent tokens ───────────────────────────────────────────────────────
    // Never readable or writable from the client.
    // Created and validated only by Cloud Functions using Admin SDK.
    match /agentTokens/{token} {
      allow read, write: if false;
    }

    // ── Deny everything else ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
