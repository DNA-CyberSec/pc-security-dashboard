# ─────────────────────────────────────────────────────────────
# PC Security Agent — Configuration
# Copy to .env and fill in your AgentToken.
# ─────────────────────────────────────────────────────────────

# Your unique AgentToken — get it from:
#   https://pcguard-rami.web.app  → Setup page after sign-in
AGENT_TOKEN=pcg-paste-your-token-here

# How often to run a full scan (seconds). Default: 300 = every 5 min
SCAN_INTERVAL=300

# How often to send a heartbeat (seconds). Default: 60
# Dashboard shows "Connected" when a heartbeat arrived within 90s.
HEARTBEAT_INTERVAL=60
